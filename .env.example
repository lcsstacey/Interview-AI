# ── AI providers (set at least one) ─────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Defaults ────────────────────────────────────────────────────────────────
DEFAULT_PROVIDER=anthropic           # anthropic | openai
DEFAULT_MODEL=claude-sonnet-4-6      # claude-sonnet-4-6 | claude-opus-4-7 | gpt-4.1 | gpt-4o ...

# ── Whisper (optional, for transcribing your own practice audio) ────────────
WHISPER_MODEL=whisper-1

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
