# Pick one or both providers. The UI lets you choose per-question.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Defaults
DEFAULT_PROVIDER=anthropic            # "openai" or "anthropic"
DEFAULT_MODEL=claude-sonnet-4-6       # e.g. claude-sonnet-4-6, claude-opus-4-7, gpt-4o, gpt-4.1, gpt-5

# Whisper (used for transcribing tab/meeting audio). Leave OPENAI_API_KEY set.
WHISPER_MODEL=whisper-1

PORT=3000
